* text=auto eol=lf

# Belt-and-suspenders for files where the wrong EOL would silently break
# the runtime: shell scripts won't shebang-parse with CRLF, systemd units
# tolerate CRLF but log warnings, Go files compile either way but stay LF
# for clean diffs.
*.sh         text eol=lf
*.go         text eol=lf
*.service    text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.md         text eol=lf
LICENSE      text eol=lf
go.mod       text eol=lf
go.sum       text eol=lf
